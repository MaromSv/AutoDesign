# AutoDesign — VLM judge keys
#
# Copy this file to `.env` (same directory) and fill in the key(s) you have.
# The project's own loader (pipeline/config.py::load_dotenv) reads `.env` at
# startup; nothing here is committed to git as long as `.env` stays in
# .gitignore.

# Default judge: Claude Opus (set in autodesign.md -> models.judge=opus,
# tier_map: opus -> claude-opus-4-8). Just need this one key to be unblocked.
ANTHROPIC_API_KEY=sk-ant-...

# Only required if you override vlm_judge.model in autodesign.md to a
# GPT/o-series model (anything matching gpt-*, o1*, o3*, o4*). Leave
# blank or delete the line otherwise — the judge will route to Anthropic.
# OPENAI_API_KEY=sk-...
