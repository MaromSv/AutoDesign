# Copy this file to `.env` and fill in your keys. `.env` is gitignored; this
# template is committed so collaborators know what's needed.
# The benchmark/autodesign loop and the rank harness auto-load `.env` (config.load_dotenv).

# Required — the VLM judge (vlm_judge, Opus 4.8) and the originality research agent.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only if you switch the judge to a gpt-* tier (models.judge: gpt-4o).
OPENAI_API_KEY=
