# AutoDesign secrets. Copy to `.env` (gitignored) and fill in. Real env vars override
# these — anything already exported wins. Loaded automatically by rank/batch and lazily
# by the Nemotron signals, so no `export` is needed.

# Claude judge (vlm_judge, references/originality). Required for the default judge tier.
ANTHROPIC_API_KEY=

# Nebius Token Factory key — powers the Nemotron signals (stress_test, prompt_consistency).
# Get it from https://studio.nebius.com (Token Factory). Override the var NAME via
# `nemotron.api_key_env` in autodesign.md if you keep it under a different name.
NEBIUS_API_KEY=

# Only needed if you point a signal at a gpt-* model instead of Claude.
# OPENAI_API_KEY=
